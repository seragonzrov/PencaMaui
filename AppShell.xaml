<?xml version="1.0" encoding="utf-8" ?>
<Shell x:Class="PencaMaui.AppShell"
       xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:views="clr-namespace:PencaMaui.Views"
       Shell.FlyoutBehavior="Disabled">

    <!-- Pantalla Login (sin tabs) -->
    <ShellContent x:Name="LoginShell"
                  Route="login"
                  ContentTemplate="{DataTemplate views:AuthPage}"
                  Shell.TabBarIsVisible="False" />

    <!-- App principal con tabs -->
    <TabBar x:Name="MainTabBar" Route="home">
        <ShellContent Title="Pencas"
                      Route="pencas"
                      ContentTemplate="{DataTemplate views:HomePencasPage}">
            <ShellContent.Icon>
                <FontImageSource FontFamily="MaterialIcons" Glyph="&#xe837;" Color="#1D9E75" Size="24" />
            </ShellContent.Icon>
        </ShellContent>
        <ShellContent Title="Perfil"
                      Route="perfil"
                      ContentTemplate="{DataTemplate views:PerfilPage}">
            <ShellContent.Icon>
                <FontImageSource FontFamily="MaterialIcons" Glyph="&#xe7fd;" Color="#1D9E75" Size="24" />
            </ShellContent.Icon>
        </ShellContent>
    </TabBar>

</Shell>
