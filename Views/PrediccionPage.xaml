<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="PencaMaui.Views.PrediccionPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:PencaMaui.ViewModels"
             xmlns:models="clr-namespace:PencaMaui.Models"
             x:DataType="vm:PrediccionViewModel"
             Title="{Binding NombrePenca}"
             BackgroundColor="#F5F5F5">
             <Shell.BackgroundColor>#1D9E75</Shell.BackgroundColor>
             <Shell.ForegroundColor>White</Shell.ForegroundColor>
             <Shell.TitleColor>White</Shell.TitleColor>

    <Grid RowDefinitions="*,Auto">

        <CollectionView Grid.Row="0" Margin="16" ItemsSource="{Binding Predicciones}">
                    <CollectionView.EmptyView>
                        <Label Text="No hay partidos disponibles"
                               TextColor="#999" FontSize="14"
                               HorizontalOptions="Center" VerticalOptions="Center"
                               HorizontalTextAlignment="Center"
                               Margin="0,40" />
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:Prediccion">
                            <Border BackgroundColor="White" Stroke="#E8E8E8"
                                    StrokeThickness="1" StrokeShape="RoundRectangle 12"
                                    Padding="14" Margin="0,0,0,10">
                                <VerticalStackLayout Spacing="10">

                                    <!-- Penca todavia abierta: vista simplificada -->
                                    <VerticalStackLayout Spacing="6"
                                            IsVisible="{Binding Source={RelativeSource AncestorType={x:Type vm:PrediccionViewModel}}, Path=PencaAbierta}">
                                        <Label Text="{Binding Partido.Fase}"
                                               FontSize="11" TextColor="#999" />
                                        <Label Text="{Binding EquiposTexto}"
                                               FontSize="15" FontAttributes="Bold"
                                               TextColor="#1A1A1A" />
                                        <Label Text="{Binding FechaHoraTexto}"
                                               FontSize="12" TextColor="#666" />
                                        <Label Text="Las predicciones se habilitan cuando el torneo arranque."
                                               FontSize="11" TextColor="#999"
                                               Margin="0,4,0,0" />
                                    </VerticalStackLayout>

                                    <!-- Penca finalizada: vista simplificada con resultado y prediccion -->
                                    <VerticalStackLayout Spacing="6"
                                            IsVisible="{Binding Source={RelativeSource AncestorType={x:Type vm:PrediccionViewModel}}, Path=PencaFinalizada}">
                                        <Label Text="{Binding Partido.Fase}"
                                               FontSize="11" TextColor="#999" />
                                        <Label Text="{Binding EquiposTexto}"
                                               FontSize="15" FontAttributes="Bold"
                                               TextColor="#1A1A1A" />
                                        <Label Text="{Binding FechaHoraTexto}"
                                               FontSize="12" TextColor="#666" />
                                        <Label Text="La penca terminó. Revisá la tabla y los ganadores."
                                               FontSize="11" TextColor="#999"
                                               Margin="0,4,0,0" />
                                        <Label FontSize="13" TextColor="#1A1A1A" IsVisible="{Binding PartidoJugado}">
                                            <Label.FormattedText>
                                                <FormattedString>
                                                    <Span Text="Resultado: " TextColor="#666" />
                                                    <Span Text="{Binding ResultadoTexto}" FontAttributes="Bold" />
                                                </FormattedString>
                                            </Label.FormattedText>
                                        </Label>
                                        <Label FontSize="13" TextColor="#1A1A1A" IsVisible="{Binding Guardado}">
                                            <Label.FormattedText>
                                                <FormattedString>
                                                    <Span Text="Tu predicción: " TextColor="#666" />
                                                    <Span Text="{Binding MiPrediccionTexto}" FontAttributes="Bold" />
                                                </FormattedString>
                                            </Label.FormattedText>
                                        </Label>
                                        <Label Text="{Binding PuntosObtenidos, StringFormat='+{0} pts'}"
                                               FontSize="13" FontAttributes="Bold" TextColor="#0F6E56"
                                               IsVisible="{Binding MostrarPuntos}" />
                                    </VerticalStackLayout>

                                    <!-- Penca en curso: vista de prediccion completa -->
                                    <VerticalStackLayout Spacing="10"
                                            IsVisible="{Binding Source={RelativeSource AncestorType={x:Type vm:PrediccionViewModel}}, Path=PencaEnCurso}">

                                    <!-- Fase + tiempo -->
                                    <Grid ColumnDefinitions="*,Auto">
                                        <Label Grid.Column="0"
                                               Text="{Binding Partido.Fase}"
                                               FontSize="11" TextColor="#999" />
                                        <Label Grid.Column="1"
                                               Text="{Binding TiempoRestante}"
                                               FontSize="11"
                                               TextColor="{Binding ColorTiempo}" />
                                    </Grid>

                                    <!-- Equipos + inputs -->
                                    <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="8">

                                        <Label Grid.Column="0"
                                               Text="{Binding Partido.EquipoLocal.Nombre}"
                                               FontSize="14" FontAttributes="Bold"
                                               TextColor="#1A1A1A"
                                               HorizontalOptions="Center"
                                               HorizontalTextAlignment="Center" />

                                        <HorizontalStackLayout Grid.Column="1"
                                                               Spacing="6"
                                                               HorizontalOptions="Center"
                                                               VerticalOptions="Center">
                                            <Border BackgroundColor="White"
                                                    Stroke ="#1D9E75"
                                                    StrokeThickness="1"
                                                    StrokeShape="RoundRectangle 8"
                                                    WidthRequest="48" HeightRequest="48">
                                                <Entry Text="{Binding GolesLocal}"
                                                       Keyboard="Numeric"
                                                       HorizontalTextAlignment="Center"
                                                       FontSize="20" FontAttributes="Bold"
                                                       TextColor="#1D9E75"
                                                       BackgroundColor="Transparent"
                                                       IsEnabled="{Binding Cerrado, Converter={StaticResource InvertBoolConverter}}" />
                                            </Border>
                                            <Label Text="–" FontSize="18"
                                                   TextColor="#999"
                                                   VerticalOptions="Center" />
                                            <Border BackgroundColor="White"
                                                    Stroke ="#1D9E75"
                                                    StrokeThickness="1"
                                                    StrokeShape="RoundRectangle 8"
                                                    WidthRequest="48" HeightRequest="48">
                                                <Entry Text="{Binding GolesVisitante}"
                                                       Keyboard="Numeric"
                                                       HorizontalTextAlignment="Center"
                                                       FontSize="20" FontAttributes="Bold"
                                                       TextColor="#1D9E75"
                                                       BackgroundColor="Transparent"
                                                       IsEnabled="{Binding Cerrado, Converter={StaticResource InvertBoolConverter}}" />
                                            </Border>
                                        </HorizontalStackLayout>

                                        <Label Grid.Column="2"
                                               Text="{Binding Partido.EquipoVisitante.Nombre}"
                                               FontSize="14" FontAttributes="Bold"
                                               TextColor="#1A1A1A"
                                               HorizontalOptions="Center"
                                               HorizontalTextAlignment="Center" />
                                    </Grid>

                                    <!-- Resultado real (partido jugado) -->
                                    <Grid ColumnDefinitions="*,Auto" IsVisible="{Binding PartidoJugado}">
                                        <Label Grid.Column="0" FontSize="13" TextColor="#1A1A1A">
                                            <Label.FormattedText>
                                                <FormattedString>
                                                    <Span Text="Resultado: " TextColor="#666" />
                                                    <Span Text="{Binding ResultadoTexto}" FontAttributes="Bold" />
                                                </FormattedString>
                                            </Label.FormattedText>
                                        </Label>
                                        <Label Grid.Column="1" Text="{Binding PuntosObtenidos, StringFormat='+{0} pts'}"
                                               FontSize="13" FontAttributes="Bold" TextColor="#0F6E56" />
                                    </Grid>

                                    <!-- Footer: estado + botón guardar -->
                                    <Grid ColumnDefinitions="*,Auto">
                                        <HorizontalStackLayout Grid.Column="0" Spacing="8">
                                            <Border BackgroundColor="#E1F5EE"
                                                    StrokeThickness="0"
                                                    StrokeShape="RoundRectangle 12"
                                                    Padding="15"
                                                    IsVisible="{Binding MostrarGuardado}">
                                                <Label Text="Guardado" FontSize="11"
                                                       TextColor="#0F6E56" />
                                            </Border>
                                            <Border BackgroundColor="#FAEEDA"
                                                    StrokeThickness="0"
                                                    StrokeShape="RoundRectangle 12"
                                                    Padding="15"
                                                    IsVisible="{Binding Cerrado}">
                                                <Label Text="Cerrado" FontSize="11"
                                                       TextColor="#633806" />
                                            </Border>
                                        </HorizontalStackLayout>
                                        <Button Grid.Column="1"
                                                Text="Guardar"
                                                BackgroundColor="#1D9E75"
                                                TextColor="White"
                                                CornerRadius="8"
                                                HeightRequest="36"
                                                FontSize="13"
                                                Padding="12,0"
                                                IsVisible="{Binding Cerrado, Converter={StaticResource InvertBoolConverter}}"
                                                CommandParameter="{Binding .}"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:PrediccionViewModel}}, Path=GuardarPrediccionCommand}" />
                                    </Grid>

                                    </VerticalStackLayout>

                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

        <!-- Mensaje estado bottom -->
        <Border Grid.Row="1" BackgroundColor="#F0F0F0" Padding="16,12"
                IsVisible="{Binding MensajeEstado, Converter={StaticResource StringToBoolConverter}}">
            <Label Text="{Binding MensajeEstado}" FontSize="13"
                   TextColor="#333" HorizontalOptions="Center" />
        </Border>

    </Grid>
</ContentPage>
