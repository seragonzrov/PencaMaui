<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="PencaMaui.Views.LoginPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:PencaMaui.ViewModels"
             xmlns:models="clr-namespace:PencaMaui.Models"
             x:DataType="vm:LoginViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="White">

    <Grid>
    <ScrollView>
        <Grid RowDefinitions="150,*" MinimumHeightRequest="600">

            <!-- Header verde -->
            <Grid Grid.Row="0" BackgroundColor="#1D9E75" Padding="24,48,24,24">
                <VerticalStackLayout VerticalOptions="End" Spacing="4">
                    <Label Text="TuPenca" FontSize="28" FontAttributes="Bold"
                           TextColor="White" FontFamily="Sans Serif" />
                    <Label Text="Competí con tus amigos en cada partido"
                           FontSize="13" TextColor="#C8F0E4" />
                </VerticalStackLayout>
            </Grid>

            <!-- Formulario -->
            <VerticalStackLayout Grid.Row="1" Padding="24,32" Spacing="16">

                <Label Text="{Binding Saludo}" FontSize="22"
                       FontAttributes="Bold" TextColor="#1A1A1A" />
                <Label Text="Ingresá a tu cuenta para ver tus pencas"
                       FontSize="13" TextColor="#666" Margin="0,-8,0,0" />

                <!-- Sitio -->
                <VerticalStackLayout Spacing="4" IsVisible="{Binding SitioSeleccionado, Converter={StaticResource NullToBoolConverter}}">
                    <Label Text="Sitio" FontSize="12" TextColor="#666" />
                    <Border Stroke="#E0E0E0" StrokeThickness="1" StrokeShape="RoundRectangle 8"
                            BackgroundColor="White">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding AbrirSelectorSitioCommand}" />
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="*,Auto" Margin="12,0" HeightRequest="44">
                            <Label Grid.Column="0" Text="{Binding SitioSeleccionado.Nombre}"
                                   TextColor="#1A1A1A" VerticalOptions="Center" FontSize="14" />
                            <Label Grid.Column="1" Text="▾" TextColor="#666"
                                   VerticalOptions="Center" Margin="0,0,4,0" />
                        </Grid>
                    </Border>
                </VerticalStackLayout>

                <!-- Email -->
                <VerticalStackLayout Spacing="4">
                    <Label Text="Email" FontSize="12" TextColor="#666" />
                    <Border Stroke="#E0E0E0" StrokeThickness="1" StrokeShape="RoundRectangle 8">
                        <Entry Text="{Binding Email}" Placeholder="tu@email.com"
                               Keyboard="Email" BackgroundColor="White"
                               TextColor="#1A1A1A" PlaceholderColor="#AAAAAA"
                               Margin="8,0" HeightRequest="44" />
                    </Border>
                </VerticalStackLayout>

                <!-- Contraseña -->
                <VerticalStackLayout Spacing="4">
                    <Label Text="Contraseña" FontSize="12" TextColor="#666" />
                    <Border Stroke="#E0E0E0" StrokeThickness="1" StrokeShape="RoundRectangle 8">
                        <Entry Text="{Binding Password}" IsPassword="True"
                               Placeholder="••••••••" BackgroundColor="White"
                               TextColor="#1A1A1A" PlaceholderColor="#AAAAAA"
                               Margin="8,0" HeightRequest="44" />
                    </Border>
                </VerticalStackLayout>

                <!-- Error -->
                <Label Text="{Binding ErrorMessage}" TextColor="#E53935"
                       FontSize="12" IsVisible="{Binding ErrorMessage, Converter={StaticResource StringToBoolConverter}}" />

                <!-- Botón Ingresar -->
                <Button Text="Ingresar" Command="{Binding LoginCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBoolConverter}}"
                        BackgroundColor="#1D9E75" TextColor="White"
                        CornerRadius="8" HeightRequest="48"
                        FontAttributes="Bold" FontSize="15" />

                <!-- Loading -->
                <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                                   Color="#1D9E75" HorizontalOptions="Center" />

                <!-- Separador -->
                <Grid ColumnDefinitions="*,Auto,*" VerticalOptions="Center" Margin="0,4">
                    <BoxView Grid.Column="0" HeightRequest="1" BackgroundColor="#E0E0E0" VerticalOptions="Center" />
                    <Label Grid.Column="1" Text="o continuá con" FontSize="11"
                           TextColor="#999" Margin="8,0" />
                    <BoxView Grid.Column="2" HeightRequest="1" BackgroundColor="#E0E0E0" VerticalOptions="Center" />
                </Grid>

                <!-- Google -->
                <Button Text="  Continuar con Google"
                        Command="{Binding LoginGoogleCommand}"
                        BackgroundColor="White" TextColor="#333"
                        BorderColor="#E0E0E0" BorderWidth="1"
                        CornerRadius="8" HeightRequest="48" FontSize="14"
                        ImageSource="google_logo.png"
                        ContentLayout="Left,10" />

                <!-- Registro -->
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="4" Margin="0,8,0,0">
                    <Label Text="¿No tenés cuenta?" FontSize="13" TextColor="#666" />
                    <Label Text="Registrate" FontSize="13" TextColor="#0F6E56"
                           FontAttributes="Bold">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding IrRegistroCommand}" />
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>

            </VerticalStackLayout>
        </Grid>
    </ScrollView>

    <!-- Overlay selector de sitio -->
    <Grid IsVisible="{Binding SitioOverlayVisible}" BackgroundColor="#80000000"
          InputTransparent="False">
        <Grid.GestureRecognizers>
            <TapGestureRecognizer Command="{Binding CerrarSelectorSitioCommand}" />
        </Grid.GestureRecognizers>
        <Border BackgroundColor="White" StrokeShape="RoundRectangle 16"
                StrokeThickness="0" Padding="24" Margin="32,0"
                VerticalOptions="Center">
            <VerticalStackLayout Spacing="8">
                <Label Text="Seleccioná tu sitio" FontSize="17" FontAttributes="Bold"
                       TextColor="#1A1A1A" HorizontalOptions="Center" Margin="0,0,0,8" />
                <VerticalStackLayout BindableLayout.ItemsSource="{Binding Sitios}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="models:SitioDto">
                            <Button Text="{Binding Nombre}"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:LoginViewModel}}, Path=ElegirSitioCommand}"
                                    CommandParameter="{Binding .}"
                                    BackgroundColor="#1D9E75" TextColor="#FFFFFFFF"
                                    CornerRadius="8" HeightRequest="44" FontSize="14"
                                    Margin="0,2" />
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </Border>
    </Grid>

    </Grid>
</ContentPage>
